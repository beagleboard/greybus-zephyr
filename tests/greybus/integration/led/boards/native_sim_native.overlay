/ {
	zephyr,greybus {
		gbbundle1 {
			status = "okay";
			compatible = "zephyr,greybus-bundle-lights";
			/* TODO: Fix after https://github.com/zephyrproject-rtos/zephyr/pull/106012 */
			lights = <&{/leds}>;
		};
	};
};
